<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Home</title>
</head>

<body>
  <h1>Generate short URLs</h1>
  <div>
    <form method="post" action="/url">
      <input type="text" placeholder="https://www.example.com" name="url">
      <button type="submit">Generate</button>
    </form>
  </div>
  <% if(locals.id) { %>
    <p>
      Generated URL:
      <a href="http://localhost:8000/url/<%= id %>" target="_blank">
        http://localhost:8000/url/<%= id %>
      </a>
    </p>
    <% } %>
      <% if(locals.urls) { %>
        <div>
          <table>
            <th>Serial</th>
            <th>Generated URLs</th>
            <th>Original URLs URL</th>
            <th>Total Clicks</th>
            <% urls.forEach((url, index)=> { %>
              <tr>
                <td>
                  <%= index + 1 %>
                </td>
                <td><a href="http://localhost:8000/url/<%= url.shortId %>" target="_blank">http://localhost:8000/url/<%=
                      url.shortId %></a></td>
                <td>
                  <%= url.redirectURL %>
                </td>
                <td>
                  <%= url.visitHistory.length %>
                </td>
              </tr>
              <% }) %>
          </table>
        </div>
        <% } %>
</body>

</html>